---
import Base from '../layouts/Base.astro';
const dl = 'https://github.com/siegerts/tama96/releases/latest/download';
const releases = 'https://github.com/siegerts/tama96/releases';
---

<Base title="tama96 - Download">
  <h1>Download</h1>
  <p class="intro">Grab the latest release for your platform. All downloads on the <a href={releases}>releases page</a>.</p>

  <section id="primary">
    <h2>Desktop app</h2>
    <div class="cards">
      <div class="card" data-platform="mac">
        <div class="card-title">macOS (Apple Silicon)</div>
        <a href={`${dl}/tama96_0.1.0_aarch64.dmg`} class="dl">Download .dmg</a>
      </div>
      <div class="card" data-platform="mac">
        <div class="card-title">macOS (Intel)</div>
        <a href={`${dl}/tama96_0.1.0_x64.dmg`} class="dl">Download .dmg</a>
      </div>
      <div class="card" data-platform="windows">
        <div class="card-title">Windows</div>
        <p>64-bit installer</p>
        <a href={`${dl}/tama96_0.1.0_x64-setup.exe`} class="dl">Download .exe</a>
      </div>
      <div class="card" data-platform="linux">
        <div class="card-title">Linux (deb)</div>
        <a href={`${dl}/tama96_0.1.0_amd64.deb`} class="dl">Download .deb</a>
      </div>
      <div class="card" data-platform="linux">
        <div class="card-title">Linux (AppImage)</div>
        <a href={`${dl}/tama96_0.1.0_amd64.AppImage`} class="dl">Download .AppImage</a>
      </div>
    </div>

    <h2>Terminal (TUI)</h2>
    <div class="cards">
      <div class="card" data-platform="mac">
        <div class="card-title">macOS (Apple Silicon)</div>
        <a href={`${dl}/tama-tui-aarch64-apple-darwin.tar.gz`} class="dl">Download .tar.gz</a>
      </div>
      <div class="card" data-platform="mac">
        <div class="card-title">macOS (Intel)</div>
        <a href={`${dl}/tama-tui-x86_64-apple-darwin.tar.gz`} class="dl">Download .tar.gz</a>
      </div>
      <div class="card" data-platform="linux">
        <div class="card-title">Linux (x64)</div>
        <a href={`${dl}/tama-tui-x86_64-unknown-linux-gnu.tar.gz`} class="dl">Download .tar.gz</a>
      </div>
      <div class="card" data-platform="windows">
        <div class="card-title">Windows (x64)</div>
        <a href={`${dl}/tama-tui-x86_64-pc-windows-msvc.zip`} class="dl">Download .zip</a>
      </div>
    </div>
    <p class="note mac-hint" data-platform="mac">macOS may block unsigned apps. After installing, run: <code>xattr -cr /Applications/tama96.app</code></p>
    <p class="note tui-hint" data-platform-hide="windows">Extract and run: <code>tar xzf tama-tui-*.tar.gz && ./tama-tui</code></p>
  </section>

  <details id="all-platforms">
    <summary>All platforms</summary>
  </details>

  <p class="note">Or build from source: <code>cargo install --git https://github.com/siegerts/tama96 tama-tui</code></p>

  <h2>Requirements</h2>
  <ul>
    <li>The MCP server requires <a href="https://nodejs.org">Node.js</a> 18+</li>
    <li>The desktop app includes everything else</li>
    <li>The TUI is a single binary with zero dependencies</li>
  </ul>

  <script>
    const ua = navigator.userAgent;
    const platform = /Mac/.test(ua) ? 'mac' : /Win/.test(ua) ? 'windows' : /Linux/.test(ua) ? 'linux' : null;
    if (platform) {
      // Hide cards that don't match the detected platform
      document.querySelectorAll('#primary .card').forEach(card => {
        if (card.dataset.platform !== platform) card.style.display = 'none';
      });
      if (platform === 'windows') {
        document.querySelector('.tui-hint')?.style.setProperty('display', 'none');
      }
      if (platform !== 'mac') {
        document.querySelector('.mac-hint')?.style.setProperty('display', 'none');
      }
    } else {
      // Can't detect — show everything
      document.getElementById('all-platforms').open = true;
    }
    // Move non-matching cards into the "All platforms" details for reference
    const details = document.getElementById('all-platforms');
    const primary = document.getElementById('primary');
    const clone = primary.cloneNode(true);
    clone.removeAttribute('id');
    clone.querySelectorAll('.card').forEach(card => card.style.display = '');
    details.appendChild(clone);
  </script>

  <style>
    h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 6px; }
    .intro { color: var(--text-secondary); margin-bottom: 36px; }
    h2 { font-size: 17px; font-weight: 600; margin-bottom: 14px; }
    .desc { color: var(--text-secondary); font-size: 14px; margin: -6px 0 14px; }
    .cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 32px; max-width: 500px; }
    .card {
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .card-title { font-size: 14px; font-weight: 600; }
    .card p { font-size: 13px; color: var(--text-tertiary); }
    .dl {
      display: inline-block;
      margin-top: auto;
      padding: 7px 16px;
      background: #2d3320;
      color: #c4cfa1;
      border-radius: var(--radius);
      font-size: 13px;
      font-weight: 500;
      text-align: center;
    }
    .dl:hover { background: #3d4530; text-decoration: none; }
    .note { font-size: 13px; color: var(--text-tertiary); margin-bottom: 6px; }
    details { margin-bottom: 24px; }
    summary {
      cursor: pointer;
      font-size: 14px;
      color: var(--text-secondary);
      margin-bottom: 16px;
    }
    summary:hover { color: var(--text-primary); }
    ul { list-style: none; padding: 0; }
    li {
      font-size: 14px;
      color: var(--text-secondary);
      padding: 3px 0 3px 18px;
      position: relative;
    }
    li::before {
      content: "";
      position: absolute;
      left: 0; top: 11px;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: #8a9470;
    }
  </style>
</Base>
