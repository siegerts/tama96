---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "A virtual pet inspired by the 1996 Tamagotchi P1" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" style="color-scheme: light;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-B3GM112FQG"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-B3GM112FQG');
    </script>
    <style is:global>
      :root {
        --teal: #5b9a9a;
        --teal-light: #e8f4f4;
        --teal-hover: #4a8282;
        --lcd-bg: #c4cfa1;
        --lcd-dark: #2d3320;
        --bg: #ffffff;
        --bg-subtle: #fafafa;
        --surface: #f5f5f5;
        --border: #e5e5e5;
        --border-hover: #d4d4d4;
        --text: #171717;
        --text-secondary: #525252;
        --text-tertiary: #a3a3a3;
        --radius: 8px;
        --radius-lg: 12px;
      }

      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        color-scheme: light;
        background: #ffffff;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #ffffff;
        color: #171717;
        line-height: 1.6;
        font-size: 15px;
      }

      a { color: var(--teal); text-decoration: none; }
      a:hover { text-decoration: underline; }

      code {
        font-family: 'JetBrains Mono', monospace;
        background: var(--surface);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 13px;
      }

      pre {
        font-family: 'JetBrains Mono', monospace;
        background: var(--bg-subtle);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 16px 20px;
        overflow-x: auto;
        font-size: 13px;
        line-height: 1.7;
        color: var(--text-secondary);
      }

      ::selection { background: rgba(91, 154, 154, 0.2); }
    </style>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href={base} class="nav-logo">tama96</a>
        <div class="nav-links">
          <a href="/docs">Docs</a>
          <a href="/download">Download</a>
          <a href="https://github.com/siegerts/tama96">GitHub</a>
        </div>
      </div>
    </nav>
    <main><slot /></main>
    <footer class="footer">
      <p>Made by <a href="https://x.com/siegerts">@siegerts</a> · Built with <a href="https://kiro.dev/">Kiro</a></p>
      <p class="tm">"Tamagotchi" is a registered trademark of Bandai Co., Ltd. Not affiliated with or endorsed by Bandai.</p>
    </footer>
    <style>
      .nav {
        border-bottom: 1px solid var(--border);
        position: sticky;
        top: 0;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        z-index: 50;
      }
      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
        height: 52px;
      }
      .nav-logo {
        font-family: 'JetBrains Mono', monospace;
        font-weight: 500;
        font-size: 15px;
        color: var(--text);
      }
      .nav-logo:hover { text-decoration: none; }
      .nav-links { display: flex; gap: 24px; font-size: 14px; }
      .nav-links a { color: var(--text-secondary); }
      .nav-links a:hover { color: var(--text); text-decoration: none; }
      main { max-width: 760px; margin: 0 auto; padding: 48px 24px 80px; }
      .footer {
        max-width: 760px;
        margin: 0 auto;
        padding: 32px 24px;
        border-top: 1px solid var(--border);
        text-align: center;
        font-size: 13px;
        color: var(--text-tertiary);
      }
      .footer a { color: var(--text-secondary); }
      .footer a:hover { color: var(--text); }
      .tm { margin-top: 6px; font-size: 11px; }
    </style>
  </body>
</html>
