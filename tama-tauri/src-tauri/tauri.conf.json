{
  "productName": "tama96",
  "version": "0.1.12",
  "identifier": "com.tama96.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "node ../../scripts/sync-version.mjs && npm --prefix ../ui run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "mcp-server-dist/*": "./"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {
        "Resources/Credits.rtf": "./Credits.rtf"
      }
    }
  }
}
